<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!--
        OacpProvider is auto-registered via manifest merger.
        Apps that depend on this library get the ContentProvider for free.
        Authority: ${applicationId}.oacp (resolved per build variant).
    -->
    <application>
        <provider
            android:name="org.oacp.android.OacpProvider"
            android:authorities="${applicationId}.oacp"
            android:exported="true"
            android:grantUriPermissions="false" />
    </application>

</manifest>
